# ============================================================
# A'Space OS V3 — .gitignore (git-publiable, NO SECRETS)
# ============================================================

# --- Secrets & credentials (NEVER commit) ---
.env
.env.*
*.pem
*.key
*.pfx
*secret*
*token*
settings.json
settings.local.json
.claude/settings.json
50_Claude_Code_Config/settings.json
history.jsonl
*.credentials.json
.mcp-auth/

# --- Claude Code runtime state (machine-local) ---
sessions/
telemetry/
ide_selection
*.jsonl
projects/
statsig/
shell-snapshots/

# --- Node ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store/
dist/
build/
.next/
.turbo/
.cache/

# --- Python ---
__pycache__/
__pycache__.bak/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# --- Heavy / non-publishable binaries ---
*.tar.gz
*.tgz
*.zip
*.7z
*.mp4
*.mov
*.avi
*.pack
takeout-*/
*takeout*/
graphify-out/
graphify-out-*/
aspace-graphify-out/

# --- Nested VCS & archives ---
.git/
_TRASH/
_TRASH_*/
_archive/

# --- Logs & temp ---
*.log
*.tmp
*.bak
*.output
.DS_Store
Thumbs.db

# V3-fix: long paths (>240 chars, Windows MAX_PATH limit)
*System Operating Blueprint_ Governance and/Artifacts/Le Code de Gouvernance RILCOT metadata.json
