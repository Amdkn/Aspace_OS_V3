# Alykaly OS — env vars template
# Copy to .env.local for dev. Set in Hostinger hPanel for production.

# ===== Supabase =====
# Local Docker (supabase start):
#   URL: http://127.0.0.1:54321
#   ANON & SERVICE keys printed by `supabase start`
# Self-hosted prod:
#   URL: https://supabase.kalybana.com
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ===== Optional integrations =====
N8N_WEBHOOK_URL=
DOCUSIGN_WEBHOOK_SECRET=

# ===== Runtime =====
PORT=4444
HOSTNAME=0.0.0.0
NEXT_TELEMETRY_DISABLED=1
